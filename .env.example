# ============================================================
# INDIS — Environment Variable Reference
# ============================================================
# Copy this file to .env and adjust values for your environment.
# Never commit .env to version control.
#
# Dev defaults are safe for local use only.
# Production values must be set explicitly in your deployment.
# ============================================================

# ── Infrastructure ────────────────────────────────────────────
# Shared infrastructure URLs used by all services.

# PostgreSQL connection string.
# In production each service should use its own database.
DATABASE_URL=postgres://indis:indis_dev_password@localhost:5432/indis_identity?sslmode=disable

# Redis connection string.
REDIS_URL=redis://localhost:6379/0

# Comma-separated Kafka broker addresses.
KAFKA_BROKERS=localhost:9092

# ── Common Service Config ─────────────────────────────────────
# These apply to most services; set per-service in docker-compose.

# gRPC server port (overrides per-service default).
GRPC_PORT=50051

# HTTP/REST server port (overrides per-service default).
HTTP_PORT=8080

# Prometheus metrics scrape port.
METRICS_PORT=9101

# Log verbosity: debug, info, warn, error.
LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────────

# HS256 shared secret for JWT signing and verification.
# MUST be changed in production to a cryptographically random value (≥32 bytes).
JWT_SECRET=indis-dev-secret-change-in-prod

# Comma-separated API key definitions for service-to-service auth.
# Format: keyID:sha256hex[,keyID:sha256hex,...]
# Example: dev-api-key-1:abc123...,svc-enrollment:def456...
API_KEYS=dev-api-key-1

# Backend gRPC transport security mode.
# Options: plaintext | tls | tls_insecure_skip_verify
# Use plaintext for local dev only; tls in all production environments.
GRPC_TLS_MODE=plaintext
BACKEND_TLS_MODE=plaintext

# Paths to TLS certificates (required when BACKEND_TLS_MODE=tls).
BACKEND_CA_FILE=
BACKEND_CLIENT_CERT_FILE=
BACKEND_CLIENT_KEY_FILE=

# ── CORS ─────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins.
# Use "*" for development only; restrict to specific origins in production.
CORS_ALLOWED_ORIGINS=*

# ── Rate Limiting ─────────────────────────────────────────────

# Maximum requests per second per IP for the gateway.
RATE_LIMIT_RPS=100

# ── Gateway — Backend Service Addresses ──────────────────────
# gRPC addresses the gateway uses to reach backend services.

IDENTITY_ADDR=localhost:9100
CREDENTIAL_ADDR=localhost:9102
ENROLLMENT_ADDR=localhost:9103
BIOMETRIC_ADDR=localhost:9104
AUDIT_ADDR=localhost:9105
NOTIFICATION_ADDR=localhost:9106
ELECTORAL_ADDR=localhost:9107
JUSTICE_ADDR=localhost:9108

# HTTP URLs for services that expose REST rather than gRPC.
VERIFIER_HTTP_URL=http://localhost:9110
CARD_HTTP_URL=http://localhost:8400
USSD_HTTP_URL=http://localhost:8300
GOV_PORTAL_HTTP_URL=http://localhost:8200

# ── Credential Service ────────────────────────────────────────

# DID used as the issuer authority for all issued credentials.
ISSUER_DID=did:indis:system

# Kafka consumer group ID for the credential service.
KAFKA_GROUP_ID=credential-service

# ── ZK Proof Service ──────────────────────────────────────────

# Base HTTP URL of the Rust zkproof service.
ZKPROOF_URL=http://localhost:8088

# Rust log filter for the zkproof service.
RUST_LOG=info

# ── AI Service ────────────────────────────────────────────────

# Base HTTP URL of the Python AI service (used by biometric service).
AI_SERVICE_URL=http://localhost:8000

# ── Card Service ──────────────────────────────────────────────

# Seed key for card issuance signing (hex-encoded Ed25519 seed).
# Leave empty to generate an ephemeral key for dev.
CARD_ISSUER_SEED=

# ── Biometric Service ─────────────────────────────────────────

# Minimum biometric match score threshold (0.0–1.0).
BIOMETRIC_MATCH_THRESHOLD=0.85

# ── Notification Service ──────────────────────────────────────

# SMS provider webhook URL (leave empty to disable SMS in dev).
SMS_PROVIDER_URL=

# Email provider SMTP or API URL (leave empty to disable email in dev).
EMAIL_PROVIDER_URL=

# ── HSM / Key Management (Production) ────────────────────────

# HSM backend driver: software | pkcs11 | azure_keyvault | aws_kms
# Use "software" for local dev; use a hardware-backed option in production.
HSM_BACKEND=software

# PKCS#11 library path (required when HSM_BACKEND=pkcs11).
HSM_PKCS11_LIB=

# ── Blockchain (Production) ───────────────────────────────────

# Blockchain backend: fabric | mock
# Use "mock" for local dev; use "fabric" in production.
BLOCKCHAIN_TYPE=mock

# Hyperledger Fabric connection profile path.
FABRIC_CONNECTION_PROFILE=

# Fabric wallet path for service identity.
FABRIC_WALLET_PATH=

# ── CouchDB (Blockchain State DB) ────────────────────────────

COUCHDB_USER=admin
COUCHDB_PASSWORD=adminpassword
COUCHDB_URL=http://localhost:5984

# ── Monitoring ────────────────────────────────────────────────

# Grafana admin password.
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Development Shortcuts ─────────────────────────────────────

# Used by tools/devtoken and tools/seed for generating dev JWTs.
DEV_GATEWAY_URL=http://localhost:8080
DEV_JWT_SECRET=indis-dev-secret-change-in-prod
