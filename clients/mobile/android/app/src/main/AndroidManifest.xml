<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".IndisApplication"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- Launcher: onboarding first, then routes to MainActivity -->
        <activity android:name=".ui.home.OnboardingActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.home.MainActivity" />
        <activity android:name=".ui.settings.SettingsActivity" />
        <activity android:name=".ui.verify.VerifyActivity" />
        <activity android:name=".ui.wallet.WalletActivity" />
        <activity android:name=".ui.enrollment.EnrollmentActivity" />
        <activity android:name=".ui.wallet.CredentialDetailActivity" />

        <!-- Push notification service (FCM) -->
        <service
            android:name=".service.IndisFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
